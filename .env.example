PORT=3000

# PostgreSQL (use either DATABASE_URL or separate params)
# DATABASE_URL=postgres://postgres:postgres@db:5432/acdc
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=acdc
DB_SSL=false

SESSION_COOKIE_NAME=acdc_session
SESSION_TTL_HOURS=720
PASSWORD_PEPPER=

# docker-compose postgres service env
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=acdc
